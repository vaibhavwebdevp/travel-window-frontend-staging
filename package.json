{
  "name": "travel-agency-frontend",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "build:tailwind": "tailwindcss -i ./src/tailwind-input.css -o ./src/tailwind.generated.css",
    "prebuild": "NG_BUILD_ENV=production node scripts/replace-env.js",
    "prebuild:staging": "NG_BUILD_ENV=staging node scripts/replace-env.js",
    "start": "npm run build:tailwind && ng serve",
    "build": "npm run build:tailwind && ng build --configuration production",
    "build:staging": "npm run prebuild:staging && npm run build:tailwind && ng build --configuration staging",
    "vercel-build": "npm run prebuild && npm run build:tailwind && ng build --configuration production",
    "vercel-build:staging": "npm run prebuild:staging && npm run build:tailwind && ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular/service-worker": "^18.2.14",
    "@sweetalert2/ngx-sweetalert2": "^14.1.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ngx-toastr": "^17.0.2",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.19",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.16",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.5.4"
  }
}
